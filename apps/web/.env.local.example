# Cobweb web — local environment overrides
# Copy to .env.local and set the API base URL.
#
# IMPORTANT: this URL is baked into the client JS bundle at build/dev time, so the
# *browser* must be able to reach it. If you browse the UI from a different LAN
# device than the one running the API, leaving this as localhost will break login
# (the browser tries localhost on its own host, not the dev server).
#
# Use the dev box's LAN IP, e.g. http://192.168.0.144:8000

NEXT_PUBLIC_API_BASE=http://localhost:8000
