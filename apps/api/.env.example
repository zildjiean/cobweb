# Cobweb API — environment configuration
# Copy to .env and fill in. Generated values shown as REPLACE_ME.

# ---- runtime ----
COBWEB_ENV=local
COBWEB_DEBUG=true

# ---- secrets (rotate per environment) ----
# Generate with: openssl rand -hex 32
COBWEB_SECRET_KEY=REPLACE_ME_openssl_rand_hex_32
COBWEB_WORKER_TOKEN=REPLACE_ME_openssl_rand_hex_32

# ---- data stores (match docker-compose.yml service names + creds) ----
COBWEB_DATABASE_URL=postgresql+asyncpg://cobweb:cobweb@localhost:5432/cobweb
COBWEB_REDIS_URL=redis://localhost:6379/0
COBWEB_RABBITMQ_URL=amqp://cobweb:cobweb@localhost:5672/

# ---- object storage (MinIO, S3-compatible) ----
COBWEB_S3_ENDPOINT=http://localhost:9000
COBWEB_S3_ACCESS_KEY=cobweb
COBWEB_S3_SECRET_KEY=cobwebsecret
COBWEB_S3_BUCKET=cobweb-artifacts

# ---- search / audit ----
COBWEB_OPENSEARCH_URL=http://localhost:9200

# ---- CORS — comma-separated list of origins allowed to call the API ----
# Add your LAN IP (and any prod hostnames) here. The web server's NEXT_PUBLIC_API_BASE
# origin MUST appear in this list, or the browser blocks every request.
COBWEB_CORS_ALLOWED_ORIGINS_RAW=http://localhost:3000

# ---- dev-only conveniences (set to false in prod) ----
COBWEB_DEV_SKIP_TARGET_VERIFICATION=true
