<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Cobweb scan report — {{ scan.id[:8] }}</title>
<style>
  @page { size: A4; margin: 18mm 18mm 22mm 18mm; }
  body { font-family: -apple-system, "Segoe UI", Inter, sans-serif; color: #0f1c30; font-size: 11pt; }
  h1 { color: #1a3aa3; margin: 0 0 4pt; }
  h2 { color: #1a3aa3; border-bottom: 1px solid #ccd; padding-bottom: 4pt; margin-top: 18pt; }
  .header { border-bottom: 3px solid #5b8def; padding-bottom: 10pt; margin-bottom: 16pt; }
  .meta { font-size: 9pt; color: #555; }
  .summary { display: flex; gap: 8pt; }
  .summary .cell { flex: 1; border: 1px solid #ccd; border-radius: 4pt; padding: 6pt 8pt; text-align: center; }
  .sev-critical { color: #c01515; }
  .sev-high { color: #d96118; }
  .sev-medium { color: #c08a0a; }
  .sev-low { color: #2c8a3a; }
  .sev-info { color: #555; }
  table { width: 100%; border-collapse: collapse; font-size: 9.5pt; margin-top: 6pt; }
  th { background: #f3f5fc; text-align: left; padding: 5pt 6pt; border-bottom: 1px solid #ccd; }
  td { padding: 5pt 6pt; vertical-align: top; border-bottom: 1px solid #eef; }
  td.tpl { font-family: "Menlo", monospace; font-size: 8.5pt; color: #333; }
  .pill { display: inline-block; padding: 2pt 5pt; border-radius: 3pt; font-size: 8.5pt; font-weight: 600; }
  .pill-critical { background: #ffd9d9; color: #8a0a0a; }
  .pill-high { background: #ffe1c8; color: #7a3a00; }
  .pill-medium { background: #fff3c4; color: #6e530b; }
  .pill-low { background: #cdebd1; color: #1c5728; }
  .pill-info { background: #e7e9f1; color: #404655; }
  .compliance ul { margin: 0; padding-left: 14pt; font-size: 9pt; }
  footer { position: fixed; bottom: 6mm; left: 0; right: 0; text-align: center; font-size: 8pt; color: #888; }
</style>
</head>
<body>

<div class="header">
  <h1>{{ report_title }}</h1>
  <div class="meta">
    Generated {{ generated_at }} · Cobweb DAST Platform · Scan {{ scan.id }}
  </div>
</div>

<h2>Executive summary</h2>
<p>
  Target <strong>{{ target.base_url }}</strong> was scanned with the
  <strong>{{ scan.engine }}</strong> engine using the
  <strong>{{ scan.profile }}</strong> profile.
  The scan {{ scan.status }} with <strong>{{ findings|length }}</strong> finding(s).
</p>

<div class="summary">
  {% for sev in ["critical", "high", "medium", "low", "info"] %}
  <div class="cell">
    <div style="font-size: 18pt; font-weight: 700;" class="sev-{{ sev }}">
      {{ summary.get(sev, 0) }}
    </div>
    <div style="text-transform: uppercase; font-size: 8pt;" class="sev-{{ sev }}">{{ sev }}</div>
  </div>
  {% endfor %}
</div>

<h2>Findings</h2>
<table>
  <thead>
    <tr>
      <th>Severity</th><th>Template</th><th>Name</th><th>Matched at</th>
    </tr>
  </thead>
  <tbody>
  {% for f in findings %}
    <tr>
      <td><span class="pill pill-{{ f.severity }}">{{ f.severity }}</span></td>
      <td class="tpl">{{ f.template_id }}</td>
      <td>{{ f.name }}</td>
      <td class="tpl">{{ f.matched_at }}</td>
    </tr>
  {% endfor %}
  {% if not findings %}
    <tr><td colspan="4" style="text-align:center; color:#777;">No findings.</td></tr>
  {% endif %}
  </tbody>
</table>

{% if compliance %}
<h2>Compliance mapping</h2>
<table class="compliance">
  <thead>
    <tr><th>Finding</th><th>OWASP Top 10</th><th>PCI-DSS 6.5</th><th>ISO 27001 A.</th></tr>
  </thead>
  <tbody>
  {% for row in compliance %}
    <tr>
      <td>{{ row.name }}</td>
      <td>{% if row.owasp %}{{ row.owasp[0] }} — {{ row.owasp[1] }}{% else %}—{% endif %}</td>
      <td>
        <ul>{% for r in row.pci %}<li>{{ r[0] }} {{ r[1] }}</li>{% endfor %}</ul>
        {% if not row.pci %}—{% endif %}
      </td>
      <td>
        <ul>{% for c in row.iso %}<li>{{ c[0] }} {{ c[1] }}</li>{% endfor %}</ul>
        {% if not row.iso %}—{% endif %}
      </td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

<footer>Cobweb · {{ generated_at }}</footer>
</body>
</html>
