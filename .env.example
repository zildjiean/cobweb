# ─────────── App ───────────
COBWEB_ENV=local
COBWEB_DEBUG=true
COBWEB_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
COBWEB_ACCESS_TOKEN_TTL_MIN=30
COBWEB_REFRESH_TOKEN_TTL_DAYS=14

# ─────────── Database ───────────
COBWEB_DATABASE_URL=postgresql+asyncpg://cobweb:cobweb@localhost:5432/cobweb

# ─────────── Redis ───────────
COBWEB_REDIS_URL=redis://localhost:6379/0

# ─────────── RabbitMQ ───────────
COBWEB_RABBITMQ_URL=amqp://cobweb:cobweb@localhost:5672/

# ─────────── MinIO ───────────
COBWEB_S3_ENDPOINT=http://localhost:9000
COBWEB_S3_ACCESS_KEY=cobweb
COBWEB_S3_SECRET_KEY=cobwebsecret
COBWEB_S3_BUCKET=cobweb-artifacts
COBWEB_S3_REGION=us-east-1

# ─────────── OpenSearch ───────────
COBWEB_OPENSEARCH_URL=http://localhost:9200

# ─────────── Web ───────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXTAUTH_SECRET=change-me-too
